{
  "$schema": "https://kiro.dev/schemas/settings.json",
  "version": "1.0",
  "project": {
    "name": "steve-kaschimer.github.io",
    "description": "AI-SDLC Framework enabled project"
  },
  "prompts": {
    "framework": ".kiro/prompts/framework.md"
  },
  "commands": {
    "directory": ".kiro/prompts"
  },
  "context": {
    "include": [
      "docs/README.md",
      "specs/**/*.md",
      ".specify/**/*.md"
    ],
    "exclude": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**"
    ]
  }
}