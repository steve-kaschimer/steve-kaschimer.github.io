node_modules/
dist/
build/
coverage/
.next/
.turbo/
.cache/

.git/
.idea/
.vscode/

*.log
*.lock
*.bin

# Secrets and environment files
.env
.env.*
*.pem
*.key
secrets/

# Framework-managed generated artifacts
.agents/
